---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import ProjectGallery from "@components/ProjectGallery.astro";
import { SITE_CONTENT } from "@config";
import type { ProjectProps } from "@types";

import "../styles/global.css";

const currentProjectName = "Soccer Bot";
const otherProjects = SITE_CONTENT.projects.filter(
  ({ name }) => name !== currentProjectName,
) as ProjectProps[];

const galleryItems = [
  { image: "/project_images/soccer_bot/5.jpeg", caption: "Soccer bot chassis design" },
  { image: "/project_images/soccer_bot/1.png", caption: "Robot assembly" },
  { image: "/project_images/soccer_bot/3.webp", caption: "Field testing" },
  { image: "/project_images/soccer_bot/6.jpg", caption: "Field testing" },
  { image: "/project_images/soccer_bot/9.jpg", caption: "Field testing" },
  { image: "/project_images/soccer_bot/12.jpg", caption: "Field testing" },

  { image: "/project_images/soccer_bot/4.jpg", caption: "Match play" },
];
---

<Layout>
  <div class="min-h-screen bg-black text-neutral">
    <Section text="Soccer Bot" href="soccer_bot" class="py-16" linkHome={true}>
      <p class="max-w-3xl text-base leading-8 text-neutral">An RC-controlled soccer robot built for competitive gameplay and hands-on robotics learning, blending mechanical precision and motion control.</p>

      <div class="mt-10 grid gap-8 rounded-3xl border border-neutral/20 bg-black p-6 shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)] sm:p-10 lg:grid-cols-1 lg:items-center">
        <div>
          <p class="mb-3 text-sm uppercase tracking-[0.28em] text-primary">Project details</p>
          <h2 class="mb-5 text-4xl font-semibold text-white">RC soccer robot with mechanical and motor control for interactive gameplay.</h2>
          <p class="mb-8 leading-8 text-neutral">This Soccer Bot project focuses on robot design, remote control, and motor-driven actuation to create an engaging platform for soccer-style robotics challenges.</p>
          <div class="flex flex-wrap gap-4">
            <a class="rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:opacity-90" href="https://md-masrul-khan.framer.website/soccer_bot" target="_blank">View original</a>
            <a class="rounded-full border border-primary/40 bg-transparent px-6 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href="mailto:masrulkhan2020@gmail.com">Contact</a>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 mt-10">
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-[#111827]/70 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.08)] h-[15rem]">
          <img src="/project_images/soccer_bot/5.jpeg" alt="Soccer Bot design" class="h-full w-full object-cover object-center" />
        </div>
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-[#111827]/70 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.08)] h-[15rem]">
          <img src="/project_images/soccer_bot/10.jpg" alt="Soccer Bot" class="h-full w-full object-cover object-center" />
        </div>
      </div>
    </Section>

    <Section text="Overview" href="overview" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">The Soccer Bot is a remotely operated robot designed for soccer gameplay, combining durable mechanical design with precise motor control and responsive remote steering.</p>
      </div>
    </Section>

    <Section text="Contributions" href="contributions" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Mechanical Design</h3>
          <p class="leading-8 text-justify">Designed the chassis and wheel assembly to support fast, stable movement during match play.</p>
          
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Motor Control</h3>
          <p class="leading-8 text-justify">Integrated motor drivers and remote control systems for smooth directional control and speed modulation.</p>
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Gameplay Interaction</h3>
          <p class="leading-8 text-justify">Built the robot to support agile movement and interactive ball control during soccer-style challenges.</p>
          
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Electronics</h3>
          <p class="leading-8 text-justify">Designed the control electronics for reliable RC reception and power distribution to the drivetrain.</p>
          
        </article>
      </div>
    </Section>

    <Section text="Impact" href="impact" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">The Soccer Bot project created a fast and responsive robot for playing soccer-style matches, demonstrating strong mechanical integrity, motor control, and effective RC-based operation.</p>
      </div>
    </Section>

    <Section text="Gallery" href="gallery" class="py-16">
      <ProjectGallery items={galleryItems} />
    </Section>

    <Section text="Videos" href="videos" class="py-16">
    <div class="grid gap-6 lg:grid-cols-2">
      <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
        <div class="relative aspect-video overflow-hidden rounded-t-3xl">
          <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/7H5BqS4fYRg" title="Soccer Bot Design" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="p-6">
          <h3 class="mb-3 text-xl font-semibold text-white">Soccer Bot Design</h3>
          <p class="text-neutral leading-7 text-justify">See the design of first soccer bot prototype in exploded view.</p>
        </div>
      </article>
      <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
        <div class="relative aspect-video overflow-hidden rounded-t-3xl">
          <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/qcyhuw28I50" title="Testing Soccer Bot" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="p-6">
          <h3 class="mb-3 text-xl font-semibold text-white">Soccer Bot Testing</h3>
          <p class="text-neutral leading-7 text-justify">Testing the soccer bot wheel motion and quick response capabilities.</p>
        </div>
      </article>
      <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
        <div class="relative aspect-video overflow-hidden rounded-t-3xl">
          <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/PgJZCL9HqwU" title="Testing Soccer Bot" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="p-6">
          <h3 class="mb-3 text-xl font-semibold text-white">Soccer Bot Testing</h3>
          <p class="text-neutral leading-7 text-justify">Testing the soccer bot wheel motion and quick response capabilities.</p>
        </div>
      </article>
      <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
        <div class="relative aspect-video overflow-hidden rounded-t-3xl">
          <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/0qSCzjKRO5c" title="Match Playback" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div>
        <div class="p-6">
          <h3 class="mb-3 text-xl font-semibold text-white">Soccer Bot Match Playback in EEE Day, KUET</h3>
          <p class="text-neutral leading-7 text-justify">Watch the soccer bot in action during the EEE Day event at KUET.</p>
        </div>
      </article>
    </div>
  </Section>

    <Section text="External Links" href="external-links" class="py-16">
      <div class="space-y-4 rounded-3xl border border-neutral/20 bg-black p-8 text-neutral">
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="https://md-masrul-khan.framer.website/soccer_bot" target="_blank">View original Framer page</a>
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="mailto:masrulkhan2020@gmail.com">Contact</a>
      </div>
    </Section>

    <Section text="Other Projects" href="other-projects" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        {otherProjects.map(({ name, summary, linkPreview }) => (
          <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
            <h3 class="mb-3 text-xl font-semibold text-white">{name}</h3>
            <p class="mb-6 text-neutral">{summary}</p>
            <a class="inline-flex rounded-full border border-primary/40 bg-transparent px-5 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href={linkPreview}>
              View project
            </a>
          </article>
        ))}
      </div>
    </Section>
  </div>
</Layout>
