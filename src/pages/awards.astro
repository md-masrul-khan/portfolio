---
<Layout>
  <div class="min-h-screen bg-black text-neutral">
    <Section text="Awards & Certifications" href="awards" class="py-16" linkHome={true}>
      <p class="max-w-3xl text-base leading-8 text-neutral">
        A collection of awards, certifications, and recognition received for excellence in robotics, research, and engineering. Each award represents dedication to technical innovation, professional growth, and meaningful contributions to the field.
      </p>
    </Section>

    <Section text="Awards & Certifications" href="awards-list" class="py-16">
      <div class="space-y-8">
        {awardsWithCertificates.map(({ title, issuer, year, description, websites, certificateImages }) => (
          <article class="overflow-hidden rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
            {/* Award Header */}
            <div class="p-8 sm:p-10">
              <p class="mb-3 text-sm uppercase tracking-[0.28em] text-primary">{issuer}</p>
              <h3 class="mb-4 text-3xl font-semibold text-white">{title}</h3>
              <p class="mb-6 text-base leading-8 text-neutral text-justify">{description}</p>
              <div class="flex flex-wrap items-center gap-4">
                <p class="text-sm font-medium text-primary">{year}</p>
                <WebsiteButtons websites={websites} />
              </div>
            </div>

            {/* Certificate Images */}
            {certificateImages?.length && (
              <div class="space-y-4 px-8 pb-8 sm:px-10">
                {certificateImages.map(({ src, alt, className }) => (
                  <div
                    class={[
                      'relative mx-auto overflow-hidden rounded-3xl bg-[#111827]/70 flex items-center justify-center',
                      className ?? 'aspect-video h-[22rem]'
                    ].join(' ')}
                  >
                    <img
                      src={src}
                      alt={alt}
                      class="h-full w-full object-cover object-center"
                    />
                  </div>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </Section>

    <Section text="Impact & Recognition" href="impact" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="mb-6 leading-8">
          These awards and certifications validate the commitment to excellence in engineering, research, and innovation. They represent milestones achieved through continuous learning, collaboration with teams, and dedication to solving complex technical challenges.
        </p>
        <p class="leading-8">
          Each recognition serves as motivation to push boundaries further and contribute meaningfully to advancements in robotics and automation technologies.
        </p>
      </div>
    </Section>
  </div>
</Layout>
