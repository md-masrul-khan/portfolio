---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import ProjectGallery from "@components/ProjectGallery.astro";
import { SITE_CONTENT } from "@config";
import type { ProjectProps } from "@types";

import "../styles/global.css";

const currentProjectName = "MFI Rover";
const otherProjects = SITE_CONTENT.projects.filter(
  ({ name }) => name !== currentProjectName,
) as ProjectProps[];

const galleryItems = [
  { image: "/project_images/mfi_rover/1.jpg", caption: "MFI Rover overview" },
  { image: "/project_images/mfi_rover/2.jpg", caption: "Mechanical design" },
  { image: "/project_images/mfi_rover/3.jpg", caption: "Field testing" },
  { image: "/project_images/mfi_rover/4.jpg", caption: "Sensor integration" },
];
---

<Layout>
  <div class="min-h-screen bg-black text-neutral">
    <Section text="MFI Rover - Military, Fire-fighter and Industrial Rover" href="mfi_rover" class="py-16" linkHome={true}>
      <p class="max-w-3xl text-base leading-8 text-neutral">The MFI Rover is an advanced, all-terrain robotic platform built for military, firefighting, and industrial missions. It delivers remote inspection, sensing, and support capabilities in hazardous environments while improving operator safety and operational efficiency.</p>

      <div class="mt-10 grid gap-8 rounded-3xl border border-neutral/20 bg-black p-6 shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)] sm:p-10 lg:grid-cols-1 lg:items-center">
        <div>
          <p class="mb-3 text-sm uppercase tracking-[0.28em] text-primary">Project details</p>
          <h2 class="mb-5 text-4xl font-semibold text-white">Multipurpose rover for reconnaissance, firefighting, and industrial inspection.</h2>
          <p class="mb-8 leading-8 text-neutral">This rover integrates rugged mobility, precision sensing, and modular payloads to support reconnaissance, rescue, inspection, and hazardous operations in complex field conditions.</p>
          <div class="flex flex-wrap gap-4">
            <a class="rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:opacity-90" href="https://md-masrul-khan.framer.website/mfi_rover" target="_blank">View original</a>
            <a class="rounded-full border border-primary/40 bg-transparent px-6 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href="mailto:masrulkhan2020@gmail.com">Contact</a>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 mt-10">
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-[#111827]/70 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.08)] h-[15rem]">
          <img src="/project_images/mfi_rover/1.jpg" alt="MFI Rover design" class="h-full w-full object-cover object-center" />
        </div>
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-[#111827]/70 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.08)] h-[15rem]">
          <img src="/project_images/mfi_rover/2.jpg" alt="MFI Rover" class="h-full w-full object-cover object-center" />
        </div>
      </div>
    </Section>

    <Section text="Overview" href="overview" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">The Multipurpose Rover is an advanced, all-terrain robot designed to perform critical operations in challenging and hazardous environments. With applications across military operations, firefighting, and industrial settings, it is engineered to enhance human safety, improve operational efficiency, and provide real-time data for decision-making.</p>
      </div>
    </Section>

    <Section text="Contributions" href="contributions" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Military Operations</h3>
          <p class="leading-8 text-justify">Reconnaissance and surveillance in high-risk zones, Explosive Ordnance Disposal (EOD) support, and supply delivery to frontline teams.</p>
          <!-- 
          <img src="/project_images/MFIRover/military.jpg" alt="Military operations" class="h-[250px] w-full rounded-3xl object-cover mt-6" />
          -->
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Firefighting</h3>
          <p class="leading-8 text-justify">Fire detection and hotspot localization, victim search and rescue in hazardous areas, and remote operation to reduce firefighter exposure.</p>
          <!-- 
          <img src="/project_images/MFIRover/firefighting.jpg" alt="Firefighting" class="h-[250px] w-full rounded-3xl object-cover mt-6" />
          -->
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Industrial Inspection</h3>
          <p class="leading-8 text-justify">Inspection of pipelines, equipment, and factory floors, maintenance assistance, and emergency response during industrial accidents.</p>
          <!--
          <img src="/project_images/MFIRover/industrial.jpg" alt="Industrial" class="h-[250px] w-full rounded-3xl object-cover mt-6" />
          -->
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black/80 p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Sensor Integration</h3>
          <p class="leading-8 text-justify">Multi-sensor fusion for remote monitoring, autonomous navigation, modular payload systems, and emergency hazard detection capabilities.</p>
          <!--
          <img src="/project_images/MFIRover/sensors.jpg" alt="Sensors" class="h-[250px] w-full rounded-3xl object-cover mt-6" />
          -->
        </article>
      </div>
    </Section>

    <Section text="Impact" href="impact" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">The MFI Rover demonstrates a multipurpose robotic platform for reconnaissance, firefighting, and industrial inspection. It enables safer operations by reducing human exposure to hazards while providing reliable sensing and support capabilities in difficult environments.</p>
      </div>
    </Section>

    <Section text="Gallery" href="gallery" class="py-16">
      <ProjectGallery items={galleryItems} />
    </Section>

    <Section text="Videos" href="videos" class="py-16">
      <div class="grid gap-6 lg:grid-cols-1">
        <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
          <div class="relative aspect-video overflow-hidden rounded-t-3xl">
            <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/Z1t5aC-JKp4" title="MFI Rover overview" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-white">Rover Application Overview</h3>
            <p class="text-neutral leading-7">See the multipurpose capabilities of the MFI Rover for military, firefighting, and industrial operations.</p>
          </div>
        </article>
        <!--
        <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
          <div class="relative aspect-video overflow-hidden rounded-t-3xl">
            <iframe class="absolute inset-0 h-full w-full" src="https://www.youtube.com/embed/7kFxOp3jot4" title="MFI Rover technology" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-white">System Integration</h3>
            <p class="text-neutral leading-7">Highlights the sensor and control systems used to make the rover inspection-ready.</p>
          </div>
        </article>
        -->
      </div>
    </Section>

    <Section text="External Links" href="external-links" class="py-16">
      <div class="space-y-4 rounded-3xl border border-neutral/20 bg-black p-8 text-neutral">
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="https://md-masrul-khan.framer.website/mfi_rover" target="_blank">View original Framer page</a>
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="mailto:masrulkhan2020@gmail.com">Contact</a>
      </div>
    </Section>

    <Section text="Other Projects" href="other-projects" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        {otherProjects.map(({ name, summary, linkPreview }) => (
          <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
            <h3 class="mb-3 text-xl font-semibold text-white">{name}</h3>
            <p class="mb-6 text-neutral">{summary}</p>
            <a class="inline-flex rounded-full border border-primary/40 bg-transparent px-5 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href={linkPreview}>
              View project
            </a>
          </article>
        ))}
      </div>
    </Section>
  </div>
</Layout>
