---
import Layout from "@layouts/Layout.astro";
import Section from "@components/Section.astro";
import { SITE_CONTENT } from "@config";
import type { ProjectProps } from "@types";

import "../styles/global.css";

const currentProjectName = "BipAD Robot";
const otherProjects = SITE_CONTENT.projects.filter(
  ({ name }) => name !== currentProjectName,
) as ProjectProps[];
---

<Layout>
  <div class="min-h-screen bg-black text-neutral">
    <Section text="BipAD Robot" href="bipad_robot" class="py-16" linkHome={true}>
      <p class="max-w-3xl text-base leading-8 text-neutral">A biped robotics project that simulates human walking and balance using embedded control, sensors, and mechanical actuation.</p>

      <div class="mt-10 grid gap-8 rounded-3xl border border-neutral/20 bg-black p-6 shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)] sm:p-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="mb-3 text-sm uppercase tracking-[0.28em] text-primary">Project details</p>
          <h2 class="mb-5 text-4xl font-semibold text-white">Humanoid-style biped robot design with walking control and stability features.</h2>
          <p class="mb-8 leading-8 text-neutral text-justify">BipAD Robot focuses on creating a stable two-legged robot capable of walking and balancing using sensor feedback, actuator coordination, and embedded control logic.</p>
          <div class="flex flex-wrap gap-4">
            <a class="rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:opacity-90" href="https://md-masrul-khan.framer.website/bipad_robot" target="_blank">View original</a>
            <a class="rounded-full border border-primary/40 bg-transparent px-6 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href="mailto:masrulkhan2020@gmail.com">Contact</a>
          </div>
        </div>
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-[#111827]/70 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.08)] h-[32rem]">
          <img src="/shopify-clon.png" alt="BipAD Robot" class="h-full w-full object-cover object-center" />
        </div>
      </div>
    </Section>

    <Section text="Overview" href="overview" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">BipAD Robot is aimed at demonstrating bipedal locomotion and balance control for humanoid robotics research. The design incorporates motor actuation, sensor fusion, and control strategies to maintain stability while walking.</p>
      </div>
    </Section>

    <Section text="Contributions" href="contributions" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Mechanical Design</h3>
          <p class="leading-8">Designed the biped structure and joint layout to support dynamic walking motions with reliable load distribution.</p>
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Embedded Control</h3>
          <p class="leading-8">Implemented microcontroller-based control for coordinated leg motion, balance correction, and gait sequencing.</p>
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Sensor Integration</h3>
          <p class="leading-8">Integrated IMUs and position sensors to monitor posture and support closed-loop balance control.</p>
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
          <h3 class="mb-3 text-xl font-semibold text-white">Testing & Validation</h3>
          <p class="leading-8">Validated walking stability through iterative testing and tuning of gait parameters and motor profiles.</p>
        </article>
      </div>
    </Section>

    <Section text="Technology" href="technology" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <ul class="grid gap-4 text-neutral sm:grid-cols-2">
          <li class="rounded-3xl border border-neutral/20 bg-[#111827]/80 p-5">Humanoid biped mechanics</li>
          <li class="rounded-3xl border border-neutral/20 bg-[#111827]/80 p-5">Motor-driven leg actuation</li>
          <li class="rounded-3xl border border-neutral/20 bg-[#111827]/80 p-5">IMU and position sensing</li>
          <li class="rounded-3xl border border-neutral/20 bg-[#111827]/80 p-5">Embedded microcontroller logic</li>
          <li class="rounded-3xl border border-neutral/20 bg-[#111827]/80 p-5">Gait control and balance algorithms</li>
        </ul>
      </div>
    </Section>

    <Section text="Outcome" href="outcome" class="py-16">
      <div class="rounded-3xl border border-neutral/20 bg-black p-8 text-neutral shadow-[0_20px_80px_-50px_rgba(15,23,42,0.5)]">
        <p class="leading-8 text-neutral">The BipAD Robot project showcases a working biped platform and a strong foundation in humanoid locomotion, useful for research and educational robotics applications.</p>
      </div>
    </Section>

    <Section text="Media" href="media" class="py-16">
      <div class="grid gap-6 lg:grid-cols-2">
        <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
          <div class="relative aspect-video overflow-hidden rounded-t-3xl">
            <img src="https://i.ytimg.com/vi_webp/LLLMujGoXyc/sddefault.webp" alt="BipAD Robot video" class="absolute inset-0 h-full w-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-white">Steering & Motion</h3>
            <p class="text-neutral leading-7">Demonstrates how embedded control and actuator coordination enable stable bipedal movement.</p>
          </div>
        </article>
        <article class="rounded-3xl border border-neutral/20 bg-black shadow-[0_20px_80px_-50px_rgba(15,23,42,0.45)]">
          <div class="relative aspect-video overflow-hidden rounded-t-3xl">
            <img src="https://i.ytimg.com/vi_webp/LLLMujGoXyc/sddefault.webp" alt="BipAD Robot design" class="absolute inset-0 h-full w-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="mb-3 text-xl font-semibold text-white">Design Summary</h3>
            <p class="text-neutral leading-7">Highlights the mechanical and control system design behind the biped platform.</p>
          </div>
        </article>
      </div>
    </Section>

    <Section text="External Links" href="external-links" class="py-16">
      <div class="space-y-4 rounded-3xl border border-neutral/20 bg-black p-8 text-neutral">
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="https://md-masrul-khan.framer.website/bipad_robot" target="_blank">View original Framer page</a>
        <a class="block rounded-2xl border border-neutral/20 bg-black/70 px-6 py-4 text-primary transition hover:border-primary hover:bg-[#111827]" href="mailto:masrulkhan2020@gmail.com">Contact</a>
      </div>
    </Section>

    <Section text="Other Projects" href="other-projects" class="py-16">
      <div class="grid gap-6 md:grid-cols-2">
        {otherProjects.map(({ name, summary, linkPreview }) => (
          <article class="rounded-3xl border border-neutral/20 bg-black p-6 text-neutral transition hover:border-primary/50 hover:bg-[#111827]/95">
            <h3 class="mb-3 text-xl font-semibold text-white">{name}</h3>
            <p class="mb-6 text-neutral">{summary}</p>
            <a class="inline-flex rounded-full border border-primary/40 bg-transparent px-5 py-3 text-sm font-medium text-primary transition hover:bg-primary/10" href={linkPreview}>
              View project
            </a>
          </article>
        ))}
      </div>
    </Section>
  </div>
</Layout>
