---
import Section from "./Section.astro";
import type { BlogPost } from "@types";

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<Section text="Blog" href="blog">
  <div class="grid gap-6">
    {posts.map(({ title, summary, link, date }) => (
      <article class="rounded-xl border border-neutral/20 bg-black p-6">
        <h3 class="mb-2 font-serif text-2xl text-primary">{title}</h3>
        {date ? <p class="text-sm text-neutral">{date}</p> : null}
        {summary ? <p class="mt-3 text-base text-neutral">{summary}</p> : null}
        {link ? <a href={link} target="_blank" class="mt-4 inline-block hover:underline">Read more</a> : null}
      </article>
    ))}
  </div>
</Section>
