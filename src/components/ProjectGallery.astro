---
interface GalleryItem {
  image: string;
  caption: string;
}

interface Props {
  items: GalleryItem[];
}

const { items } = Astro.props;
---

<div class="overflow-hidden">
  {/* Duplicate the items sequence to create a seamless looping scroll */}
  <div class="flex gap-6 w-max animate-scroll">
    {(items.concat(items)).map(({ image, caption }, i) => (
      <div class="max-w-[20%] md:max-w-[16%]" aria-hidden={i >= items.length}>
        <div class="overflow-hidden rounded-3xl border border-neutral/20 bg-black h-[16rem]">
          <img src={image} alt={caption} class="h-full w-full object-cover" />
        </div>
        <p class="mt-3 text-sm text-neutral">{caption}</p>
      </div>
    ))}
  </div>
</div>
