---
import Section from "./Section.astro";
import type { AwardProps } from "@types";

interface Props {
  awards: AwardProps[];
}

const { awards } = Astro.props;
---

<Section text="Awards" href="awards">
  <div class="mb-8 max-w-3xl">
    <p class="text-base leading-8 text-neutral">Recognition and awards received for excellence in robotics, research, and engineering achievements. These certifications represent dedication to technical innovation and professional development.</p>
  </div>
  <div class="grid gap-4">
    {awards.map(({ title, issuer, year, description }) => (
      <div class="rounded-xl border border-neutral/20 bg-black p-4">
        <h4 class="font-medium text-lg text-white">{title}</h4>
        {issuer || year ? <p class="text-sm text-neutral">{issuer} {issuer && year ? `· ${year}` : year}</p> : null}
        {description ? <p class="mt-2 text-neutral">{description}</p> : null}
      </div>
    ))}
  </div>
  <div class="mt-8">
    <a href="/awards" class="inline-flex rounded-full bg-primary px-6 py-3 text-sm font-medium text-white transition hover:opacity-90">
      View all awards
    </a>
  </div>
</Section>
